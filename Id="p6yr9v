name: Stavební poptávka
description: Vyplň tento formulář pro novou poptávku stavebních prací
title: "[Poptávka] "
labels: lead
body:
  - type: input
    id: jmeno
    attributes:
      label: Jméno a příjmení
      placeholder: Jan Novák
  - type: input
    id: email
    attributes:
      label: E-mail
      placeholder: jan@example.com
  - type: textarea
    id: popis
    attributes:
      label: Popis poptávky
      placeholder: Typ prací, termín, lokalita…
